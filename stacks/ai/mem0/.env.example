# Mem0 Configuration
# Copy to .env and fill in required values

# --- Required ---

# LLM API key for memory extraction and embeddings.
# Mem0 defaults to OpenAI for LLM + embeddings. To use Ollama instead,
# you need to reconfigure via the /configure API endpoint or modify the
# server config (see README for details).
OPENAI_API_KEY=sk-...

# PostgreSQL (pgvector) credentials
POSTGRES_USER=mem0
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mem0
POSTGRES_COLLECTION_NAME=memories

# --- Neo4j (Graph Memory) ---

# Neo4j enriches memory with entity/relationship tracking.
# Can be disabled by removing the neo4j service from compose.yml.
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=mem0graph

# --- Ollama (optional, for local embeddings/LLM) ---

# OLLAMA_API_BASE=http://ollama:11434

# --- Networking ---

# Host port for Mem0 API
MEM0_PORT=8888

# Domain for Traefik reverse proxy
MEM0_DOMAIN=mem0.local
