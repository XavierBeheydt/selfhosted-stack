# LiteLLM Configuration
# Copy to .env and fill in required values

# --- Required ---

# Master API key for LiteLLM proxy (must start with "sk-")
LITELLM_MASTER_KEY=sk-change-me

# PostgreSQL credentials for LiteLLM database
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=litellm

# --- LLM Provider API Keys (optional, add as needed) ---

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# --- Ollama ---

# Ollama API base URL (default: Docker service name)
OLLAMA_API_BASE=http://ollama:11434

# --- Networking ---

# Host port for LiteLLM API + dashboard
LITELLM_PORT=4000

# Domain for Traefik reverse proxy
LITELLM_DOMAIN=litellm.local
