# CoreDNS Configuration
# https://coredns.io/manual/toc/

# Internal zone (dynamic, generated by DNSZoner)
{$BASE_DOMAIN:localhost} {
  file /etc/coredns/zones/{$BASE_DOMAIN:localhost}.zone
  reload 15s
  log
  errors
}

# DNS-over-TLS listener
tls://.:853 {
  tls /etc/coredns/certs/cert.pem /etc/coredns/certs/key.pem
  forward . tls://1.1.1.1 tls://1.0.0.1 {
    tls_servername cloudflare-dns.com
    health_check 30s
  }
  cache 300
  log
}

# Default forward (DNSSEC validated)
. {
  forward . tls://1.1.1.1 tls://1.0.0.1 {
    tls_servername cloudflare-dns.com
    health_check 30s
  }
  dnssec
  cache 300
  log
  errors
  health :8080
}
