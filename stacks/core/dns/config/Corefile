# CoreDNS configuration
# https://coredns.io/manual/toc/

.:${DNS_PORT:-53} {
    dnssec
    log
    errors
    health localhost:8080
    cache 30

    # Load zone files generated by DNSZoner
    auto {
        directory /etc/coredns/zones (.*) db
        reload 10s
    }

    # Forward unresolved queries to upstream DNS
    forward . {$DNS_FORWARD_TO} {
        tls_servername {$DNS_FORWARD_TLS_NAME}
        health_check 5s
        max_concurrent 10
        policy random
    }
}
