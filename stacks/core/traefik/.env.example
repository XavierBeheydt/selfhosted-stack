# =============================================================================
# Traefik - Service-specific environment
# =============================================================================
# Copy to .env and adjust values.

BASE_DOMAIN=example.com
TZ=Europe/Paris
ACME_EMAIL=admin@example.com

# Container engine socket
# Docker:
# CONTAINER_ENGINE_SOCKET=/var/run/docker.sock
# Podman rootless:
# CONTAINER_ENGINE_SOCKET=/run/user/1000/podman/podman.sock

# Dashboard basic auth (generate with: htpasswd -nB admin)
# TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$...
