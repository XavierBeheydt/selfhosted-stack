# =============================================================================
# WireGuard - Service-specific environment
# =============================================================================

# Public hostname or IP of the VPN server (required)
WG_HOST=vpn.example.com

# Password hash for the web UI (generate with: wgpw 'your-password')
# WG_PASSWORD_HASH=$$2y$$...

# WireGuard listen port
WG_PORT=51820

# DNS server for VPN clients (use CoreDNS IP for internal resolution)
WG_DEFAULT_DNS=10.13.13.1

# VPN client address range
WG_DEFAULT_ADDRESS=10.13.13.x

# Networks accessible through VPN
# Include K3s pod and service CIDRs for full cluster access
WG_ALLOWED_IPS=10.13.13.0/24, 10.42.0.0/16, 10.43.0.0/16

BASE_DOMAIN=example.com
