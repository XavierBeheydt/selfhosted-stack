# =============================================================================
# Dolibarr - Service-specific environment
# =============================================================================

# Database
DOLI_DB_ROOT_PASSWORD=changeme_root
DOLI_DB_NAME=dolidb
DOLI_DB_USER=dolidbuser
DOLI_DB_PASSWORD=changeme_db

# Dolibarr admin
DOLI_ADMIN_LOGIN=admin
DOLI_ADMIN_PASSWORD=changeme_admin

# Application
DOLI_TAG=latest
DOLI_INSTALL_AUTO=1
DOLI_INIT_DEMO=0
DOLI_CRON=0
DOLI_CRON_KEY=changeme_cron_key
DOLI_COMPANY_NAME=MyCompany
DOLI_URL_ROOT=https://erp.example.com
DOLI_DOMAIN=erp.example.com

TZ=Europe/Paris
