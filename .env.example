# =============================================================================
# selfhosted-stack - Global Configuration
# =============================================================================
# Copy this file to .env and adjust values to your environment.
# Each stack may also have its own .env.example for service-specific settings.

# -- General ------------------------------------------------------------------
TZ=Europe/Paris
BASE_DOMAIN=example.com

# -- Container Engine ---------------------------------------------------------
# Uncomment the appropriate socket for your container engine.
# Docker (default):
# CONTAINER_ENGINE_SOCKET=/var/run/docker.sock
# Podman rootless:
# CONTAINER_ENGINE_SOCKET=/run/user/1000/podman/podman.sock

# -- Traefik ------------------------------------------------------------------
ACME_EMAIL=admin@example.com
# TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$...  # htpasswd -nB admin

# -- DNS ----------------------------------------------------------------------
DNS_HOST=0.0.0.0
DNS_PORT=53

# -- WireGuard VPN Gateway ----------------------------------------------------
# WG_HOST=vpn.example.com        # Public hostname or IP of VPN server
# WG_DEFAULT_DNS=10.13.13.1      # DNS server for VPN clients
# WG_ALLOWED_IPS=10.13.13.0/24   # VPN subnet

# -- K3s (production) --------------------------------------------------------
# K3S_TOKEN=changeme              # Shared token for joining nodes
# K3S_URL=https://vps-ip:6443    # API server URL (on agent nodes)
