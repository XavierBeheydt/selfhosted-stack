# =============================================================================
# selfhosted-stack - Global Configuration
# =============================================================================
# Copy to .env and adjust values. Each stack has its own .env.example too.

# -- General ------------------------------------------------------------------
TZ=Europe/Paris
BASE_DOMAIN=example.com

# -- Container Engine ---------------------------------------------------------
# Default: podman. Override to use docker.
CONTAINER_ENGINE=podman
# Podman rootless:
# CONTAINER_ENGINE_SOCKET=/run/user/1000/podman/podman.sock
# Docker:
# CONTAINER_ENGINE_SOCKET=/var/run/docker.sock

# -- Traefik ------------------------------------------------------------------
ACME_EMAIL=admin@example.com

# -- DNS ----------------------------------------------------------------------
DNS_HOST=0.0.0.0
DNS_PORT=53

# -- WireGuard ----------------------------------------------------------------
# WG_HOST=vpn.example.com
# WG_PASSWORD=changeme
# WG_DEFAULT_DNS=10.13.13.1
# WG_ALLOWED_IPS=10.13.13.0/24
